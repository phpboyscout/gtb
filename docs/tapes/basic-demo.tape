# gtb Demo Tape
# Generated by Antigravity

Require gtb
Require go
Require golangci-lint

Output basic-demo.mp4

Set Shell "bash"
Set FontSize 22
Set Width 1400
Set Height 1100
Set Padding 10
Set Framerate 20

Env AI_PROVIDER "claude"

Hide
Type "export PS1='$> '" Enter
Type "rm -rf ./my-cli" Enter
Type "clear" Enter
Show

# Start the demo
Type "mkdir -p my-cli && cd my-cli" Enter
Sleep 500ms
Type "gtb generate cli" Enter
Sleep 500ms

# Fill out the skeleton form
# Project Name
Type "my-cli" Enter
Sleep 500ms
# GitHub Repository
Type "ptps/my-cli" Enter
Sleep 500ms
# Git Host (default)
Enter
Sleep 500ms
# Description
Enter
Sleep 500ms
# Destination Path (default .)
Enter
Sleep 500ms
# Features (Multi-select, all enabled by default)
Space
Down
Space
Sleep 500ms
Enter

Wait+Line@30s /\$>/
Sleep 1s

# Show the results
Type "ls" Enter
Sleep 1s

# Generate 'example' command
Type "gtb generate command" Enter
Sleep 500ms

# Fill out the command form
# Command Name
Type "example" Enter
Sleep 500ms
# Short Description
Type "This is an example generated command" Enter
Sleep 500ms
# Long Description
Type "A long multi-line description"
Ctrl+J
Type "for an example generated command" Enter
Sleep 500ms
# Parent Command
Enter
Sleep 500ms
# Options (Multi-select, all disabled by default)
Enter
Sleep 500ms
Enter
Wait+Line@30s /\$>/
Sleep 1s

# Inspect files
Type "vim pkg/cmd/example/cmd.go"
Sleep 500ms
Enter
Sleep 2s
Escape
Type ":q" Enter
Sleep 500ms

# Use vim to add log output (simulated)
Type "vim pkg/cmd/example/main.go"
Sleep 500ms
Enter
Sleep 4s
Type "/return" Enter
Sleep 1s
Type "O"
Type 'props.Logger.Info("This is an example generated command")' Enter
Escape
Type ":wq" Enter
Sleep 500ms

# Compilation
Type "go build -o my-cli ./cmd/my-cli" Enter

Wait+Line@5s /\$>/

# Run commands
Type "./my-cli example --help" Enter
Sleep 1s

# Run commands
Type "./my-cli example" Enter
Sleep 5s
