# gtb Demo Tape
# Generated by Antigravity

Require gtb
Require go
Require golangci-lint

Output flags-demo.mp4

Set Shell "bash"
Set FontSize 22
Set Width 1400
Set Height 1100
Set Padding 10
Set Framerate 20

Env AI_PROVIDER "claude"

Hide
Type "export PS1='$> '" Enter
Type "cd my-cli" Enter
Type "rm -rf ./my-cli" Enter
Type "clear" Enter
Show

Sleep 500ms

Type "go run cmd/my-cli/main.go example --help" Enter
Sleep 2s

Type "gtb generate add-flag" Enter
Sleep 500ms

# Fill out the flag form
# Command Name
Type "example" Enter
Sleep 500ms
# Flag Name
Type "foo" Enter
Sleep 500ms
# Flag Type
Down
Enter
Sleep 500ms
# Flag Description
Type "This is a new flag" Enter
Sleep 500ms
# Persistent
Enter
Sleep 500ms
# Path to project root
Enter
Sleep 500ms

Wait+Line@30s /\$>/
Sleep 1s

# Inspect files
Type "vim pkg/cmd/example/cmd.go"
Sleep 500ms
Enter
Type "/Bool"
Sleep 4s
Escape
Type ":q" Enter
Sleep 500ms


Type "go run cmd/my-cli/main.go example --help" Enter
Sleep 2s


Type "gtb generate add-flag --command example --name bar --type string --description 'This is another new flag'" Enter

Wait+Line@30s /\$>/
Sleep 1s

# Inspect files
Type "vim pkg/cmd/example/cmd.go"
Sleep 500ms
Enter
Type "/String"
Sleep 4s
Escape
Type ":q" Enter
Sleep 500ms
