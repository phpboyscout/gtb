# gtb Demo Tape
# Generated by Antigravity

Require gtb
Require go
Require golangci-lint

Output prompt-demo.mp4

Set Shell "bash"
Set FontSize 22
Set Width 1400
Set Height 1100
Set Padding 20
Set Framerate 20

Env AI_PROVIDER "claude"

Hide
Type "export PS1='$> '" Enter
Type "cd my-cli" Enter
Type "rm -rf ./my-cli" Enter
Type "rm -rf ./pkg/cmd/info" Enter
Type "clear" Enter
Show

Sleep 500ms

# Generate 'info' command with prompt
Type 'gtb generate command -n info --prompt "print out the contents of /etc/os-release to stdout"' Enter
Sleep 500ms

Wait+Line@300s /\$>/
Sleep 500ms

# Inspect 'info' command
Type "vim pkg/cmd/info/main.go" Enter
Sleep 4s
Escape
Type ":q" Enter
Sleep 500ms

# Compilation
Type "go build -o my-cli ./cmd/my-cli" Enter
Sleep 500ms

# Run commands
Type "./my-cli info" Enter
Sleep 2s
