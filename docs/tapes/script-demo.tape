# gtb Demo Tape
# Generated by Antigravity

Require gtb
Require go
Require golangci-lint

Output script-demo.mp4

Set Shell "bash"
Set FontSize 22
Set Width 1400
Set Height 1100
Set Padding 20
Set Framerate 15

Env AI_PROVIDER "claude"

Hide
Type "export PS1='$> '" Enter
Type "cd my-cli" Enter
Type "rm -rf ./pkg/cmd/backup" Enter
Type "rm -rf ./my-cli" Enter
Type "clear" Enter
Show
Sleep 1s

# Inspect 'backup' command
Type "vim ../backup.sh" Enter
Sleep 4s
Escape
Type ":q" Enter
Sleep 500ms


# Generate 'backup' command from script
Type "gtb generate command -n backup --script ../backup.sh" Enter

Wait+Line@300s /\$>/
Sleep 500ms

# Inspect 'backup' command
Type "vim pkg/cmd/backup/main.go" Enter
Sleep 4s
Escape
Type ":q" Enter
Sleep 500ms

# Compilation
Type "go build -o my-cli ./cmd/my-cli" Enter
Sleep 500ms

# Run commands
Type "./my-cli backup --help" Enter
Sleep 500ms
